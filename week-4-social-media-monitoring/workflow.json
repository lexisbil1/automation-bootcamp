    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\n\nreturn inputItems[0].json.articles.map(article => {\n  return {\n    json: {\n      title: article.title || \"\",\n      snippet: article.description || \"\",\n      link: article.url || \"\",\n      timestamp: new Date().toISOString()\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
