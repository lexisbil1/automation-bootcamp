      ],
      "id": "8b49a627-c581-44d9-a33a-bfbb4ba1709e",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst negativeKeywords = [\n  \"scam\", \"fraud\", \"bad\", \"issue\", \"broken\", \"hack\", \"breach\", \"fail\", \"leak\"\n];\n\nconst positiveKeywords = [\n  \"amazing\", \"great\", \"excellent\", \"love\", \"best\", \"secure\", \"fast\", \"success\"\n];\n\nreturn items.map(item => {\n  const text = ((item.json.title || \"\") + \" \" + (item.json.snippet || \"\")).toLowerCase();\n\n  let sentiment = \"neutral\";\n\n  if (negativeKeywords.some(word => text.includes(word))) {\n    sentiment = \"negative\";\n  } else if (positiveKeywords.some(word => text.includes(word))) {\n    sentiment = \"positive\";\n  }\n\n  return {\n    json: {\n      ...item.json,\n      sentiment\n    }\n  };\n});"
      },
